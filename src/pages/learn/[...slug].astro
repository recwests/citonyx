---
import { getCollection, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import Schema from '~/components/Schema.astro';
import { SITE } from 'astrowind:config';

export const prerender = true;

export async function getStaticPaths() {
  const allPractices = await getCollection('geoPractices');
  return allPractices.map((entry) => {
    const slug = entry.id.replace(/^.*[/\\]/, '').replace(/\.[^.]+$/, '');
    return { params: { slug }, props: { id: entry.id } };
  });
}

const { id } = Astro.props as { id: string };
const entries = await getCollection('geoPractices');
const entry = entries.find((e) => e.id === id)!;
const { Content } = await render(entry);

const slug = (Astro.params.slug as string).split('/').pop()!;

const sources = (entry.data.sources ?? []).map((src) => {
  const href = /^https?:\/\//i.test(src) ? src : `https://${src}`;
  let label: string;
  try {
    label = new URL(href).hostname.replace(/^www\./, '');
  } catch {
    label = src;
  }
  return { href, label };
});

const metadata = { title: entry.data.title, description: entry.data.description };
---

<Layout metadata={metadata}>
  <Schema
    type="Article"
    headline={entry.data.title}
    datePublished={entry.data.published.toISOString()}
    author={{ name: SITE.name, url: SITE.site, type: 'Organization' }}
  />
  <Schema
    type="BreadcrumbList"
    items={[
      { name: 'Home', href: new URL('/', SITE.site).href },
      { name: 'GEO Practices', href: new URL('/learn', SITE.site).href },
      { name: entry.data.title, href: new URL(`/learn/${slug}`, SITE.site).href },
    ]}
  />
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <p class="text-sm text-muted mb-2">
      <a href="/learn" class="hover:text-primary">&larr; All Practices</a>
    </p>
    <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter">
      {entry.data.title}
    </h1>
    <div
      class="mx-auto prose prose-lg max-w-4xl dark:prose-invert dark:prose-headings:text-slate-300 prose-md prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-img:rounded-md prose-img:shadow-lg mt-8"
    >
      <Content />
    </div>
    {
      sources.length > 0 && (
        <aside class="mt-12 pt-6 border-t border-gray-200 dark:border-slate-700">
          <h2 class="font-heading font-bold text-xl tracking-tight mb-3">Sources</h2>
          <ul class="list-none space-y-2 text-sm">
            {sources.map((source) => (
              <li>
                <a
                  href={source.href}
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                  class="text-blue-600 dark:text-blue-400 hover:underline break-all"
                >
                  {source.label}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )
    }
  </section>
</Layout>
