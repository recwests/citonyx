---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Schema from '~/components/Schema.astro';
import { getCollection } from 'astro:content';
import { SITE } from 'astrowind:config';
import { entryUrl } from '~/utils/entry';

export const prerender = true;

const allPractices = await getCollection('geoPractices');

const PRACTICE_TYPE_LABELS: Record<string, string> = {
  basics: 'Basics',
  content: 'Content Strategy',
  technical: 'Technical GEO',
  measurement: 'Measurement & Analytics',
  'entity-seo': 'Entity SEO',
  'schema-markup': 'Schema & Structured Data',
  tools: 'Tools & Platforms',
  'case-studies': 'Case Studies',
  monetization: 'Monetization',
};

const difficultyColors: Record<string, string> = {
  beginner: 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
  intermediate: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200',
  advanced: 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200',
};

const grouped = allPractices.reduce<Record<string, typeof allPractices>>((acc, entry) => {
  const pt = entry.data.practice_type;
  if (!pt) return acc;
  if (!acc[pt]) acc[pt] = [];
  acc[pt].push(entry);
  return acc;
}, {});

const TAG_LABELS: Record<string, string> = {
  'ai-overviews': 'AI Overviews',
  chatgpt: 'ChatGPT',
  roi: 'ROI',
  b2b: 'B2B',
  eeat: 'E-E-A-T',
  'llms-txt': 'llms.txt',
  'robots-txt': 'robots.txt',
  'technical-seo': 'Technical SEO',
  'entity-seo': 'Entity SEO',
  'digital-pr': 'Digital PR',
  youtube: 'YouTube',
  'local-geo': 'Local GEO',
  'vertical-geo': 'Vertical GEO',
  'multi-model': 'Multi-model',
  seo: 'SEO',
};
const humanTag = (slug: string): string =>
  TAG_LABELS[slug] ??
  slug
    .split('-')
    .map((w) => w[0].toUpperCase() + w.slice(1))
    .join(' ');

const tagCounts = new Map<string, number>();
for (const entry of allPractices) {
  for (const tag of entry.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const allTags = [...tagCounts.entries()].filter(([, c]) => c >= 2).sort((a, b) => b[1] - a[1]);
---

<Layout metadata={{ title: 'GEO Practices' }}>
  <WidgetWrapper>
    <Headline
      title="GEO Practices Guide"
      subtitle="A collection of actionable practices for Generative Engine Optimization"
      tagline="Learn"
      as="h1"
    />

    <Schema
      type="ItemList"
      items={allPractices.map((entry) => ({
        name: entry.data.title,
        url: new URL(entryUrl(entry).href, SITE.site).href,
      }))}
    />

    <div class="sticky top-[70px] z-30 -mx-2 px-2 py-2 bg-white/95 dark:bg-slate-900/95 backdrop-blur-sm rounded-lg">
      <label for="learn-search" class="sr-only">Search practices</label>
      <input
        type="search"
        id="learn-search"
        placeholder={`Search ${allPractices.length} practices…`}
        autocomplete="off"
        class="w-full max-w-xl rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary"
      />
    </div>
    <div class="mb-10 mt-4">
      <div id="learn-tags" class="flex flex-wrap gap-2">
        {
          allTags.map(([tag], i) => (
            <button
              type="button"
              class={`learn-tag text-xs px-3 py-1.5 rounded-full border border-slate-300 dark:border-slate-600 hover:border-primary transition-colors${i >= 12 ? ' learn-tag-extra hidden' : ''}`}
              data-tag={tag}
            >
              {humanTag(tag)}
            </button>
          ))
        }
      </div>
      {
        allTags.length > 12 && (
          <button
            type="button"
            id="learn-tags-more"
            class="text-xs px-3 py-1.5 rounded-full text-primary hover:underline"
          >
            All tags ({allTags.length - 12}) ▾
          </button>
        )
      }
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-3">
        <p id="learn-count" class="text-sm text-muted hidden"></p>
        <div id="learn-sort" class="hidden text-xs text-muted">
          Sort:
          <button type="button" data-sort="relevance" class="learn-sort-btn font-semibold text-primary"
            >Relevance</button
          > ·
          <button type="button" data-sort="newest" class="learn-sort-btn">Newest</button>
        </div>
        <button
          type="button"
          id="learn-reset"
          class="hidden text-xs px-3 py-1.5 rounded-full border border-red-300 dark:border-red-700 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950"
          >× Clear filters</button
        >
      </div>
      <div id="learn-difficulty" class="mt-3 text-xs text-muted">
        Difficulty:
        <button type="button" data-diff="all" class="learn-diff-btn bg-primary text-white rounded-full px-2">All</button
        > ·
        <button type="button" data-diff="beginner" class="learn-diff-btn">Beginner</button> ·
        <button type="button" data-diff="intermediate" class="learn-diff-btn">Intermediate</button> ·
        <button type="button" data-diff="advanced" class="learn-diff-btn">Advanced</button>
      </div>
      <nav id="learn-toc" aria-label="Sections" class="mt-6">
        <p class="text-xs uppercase tracking-wide text-muted mb-2">Browse by category</p>
        <div class="flex flex-wrap gap-2">
          {
            Object.entries(grouped).map(([topic, entries]) => (
              <a
                href={`#topic-${topic}`}
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border-2 border-primary/40 font-medium text-sm hover:bg-primary hover:text-white transition-colors"
              >
                {PRACTICE_TYPE_LABELS[topic] || topic}
                <span class="text-xs opacity-70">({entries.length})</span>
              </a>
            ))
          }
        </div>
      </nav>
    </div>
    <div id="learn-results" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 hidden"></div>
    <button
      type="button"
      id="learn-top"
      aria-label="Back to top"
      class="hidden fixed bottom-6 right-6 z-40 w-11 h-11 rounded-full bg-primary text-white shadow-lg hover:opacity-90 transition-opacity"
      >↑</button
    >

    <div id="learn-groups">
      {
        Object.entries(grouped).map(([topic, entries]) => (
          <div class="mb-12" id={`topic-${topic}`}>
            <div class="flex items-baseline justify-between mb-6">
              <h3 class="text-2xl font-bold">{PRACTICE_TYPE_LABELS[topic] || topic}</h3>
              <a
                href={entries.length >= 5 ? `/learn/${topic}` : '/learn'}
                class="text-sm font-medium text-primary hover:underline"
              >
                View all &rarr;
              </a>
            </div>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {entries.map((entry) => {
                const { href } = entryUrl(entry);
                return (
                  <a
                    href={href}
                    class="block p-6 rounded-lg border border-slate-200 dark:border-slate-700 hover:shadow-md hover:border-slate-300 dark:hover:border-slate-600 transition-all"
                  >
                    <h4 class="text-lg font-semibold mb-2">{entry.data.title}</h4>
                    <p class="text-sm text-muted mb-4 card-clamp-3">{entry.data.description}</p>
                    <div class="flex flex-wrap gap-2 items-center">
                      <span
                        class={`text-xs px-2 py-0.5 rounded font-medium ${difficultyColors[entry.data.difficulty]}`}
                      >
                        {entry.data.difficulty}
                      </span>
                      <span class="text-xs px-2 py-0.5 rounded bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                        {entry.data.manual ? 'Article' : 'Note'}
                      </span>
                      <span class="text-xs text-muted">
                        Upd {entry.data.updated.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })}
                      </span>
                      {entry.data.tags.slice(0, 3).map((tag) => (
                        <span class="text-xs px-2 py-0.5 rounded bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        ))
      }
    </div>
  </WidgetWrapper>
</Layout>

<script>
  import Fuse from 'fuse.js';

  const PRACTICE_LABELS: Record<string, string> = {
    basics: 'Basics',
    content: 'Content Strategy',
    technical: 'Technical GEO',
    measurement: 'Measurement & Analytics',
    'entity-seo': 'Entity SEO',
    'schema-markup': 'Schema & Structured Data',
    tools: 'Tools & Platforms',
    'case-studies': 'Case Studies',
    monetization: 'Monetization',
  };
  const TAG_LABELS: Record<string, string> = {
    'ai-overviews': 'AI Overviews',
    chatgpt: 'ChatGPT',
    roi: 'ROI',
    b2b: 'B2B',
    eeat: 'E-E-A-T',
    'llms-txt': 'llms.txt',
    'robots-txt': 'robots.txt',
    'technical-seo': 'Technical SEO',
    'entity-seo': 'Entity SEO',
    'digital-pr': 'Digital PR',
    youtube: 'YouTube',
    'local-geo': 'Local GEO',
    'vertical-geo': 'Vertical GEO',
    'multi-model': 'Multi-model',
    seo: 'SEO',
  };
  // eslint-disable-next-line @typescript-eslint/no-unused-vars
  const humanTag = (slug: string): string =>
    TAG_LABELS[slug] ??
    slug
      .split('-')
      .map((w) => w[0].toUpperCase() + w.slice(1))
      .join(' ');

  const difficultyColors: Record<string, string> = {
    beginner: 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
    intermediate: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200',
    advanced: 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200',
  };

  type Practice = {
    slug: string;
    title: string;
    description: string;
    tags: string[];
    difficulty: string;
    practice_type: string;
    updated: string;
    url: string | null;
  };

  function init() {
    const input = document.getElementById('learn-search') as HTMLInputElement | null;
    const results = document.getElementById('learn-results');
    const groups = document.getElementById('learn-groups');
    const countEl = document.getElementById('learn-count');
    const tagsWrap = document.getElementById('learn-tags');
    const toc = document.getElementById('learn-toc');
    const sortEl = document.getElementById('learn-sort');
    const resetEl = document.getElementById('learn-reset');
    const diffEl = document.getElementById('learn-difficulty');
    if (!input || !results || !groups || !countEl || !tagsWrap || input.dataset.ready) return;
    input.dataset.ready = '1';

    let fuse: Fuse<Practice> | null = null;
    let all: Practice[] = [];
    const activeTags = new Set<string>();
    let sortMode: 'relevance' | 'newest' = 'relevance';
    let difficulty: string = 'all';

    async function ensureData() {
      if (fuse) return;
      const res = await fetch('/api/practices.json');
      const data = await res.json();
      all = (data.practices as Practice[]).filter((p) => p.url);
      fuse = new Fuse(all, {
        keys: [
          { name: 'title', weight: 2 },
          { name: 'description', weight: 1 },
          { name: 'tags', weight: 1.5 },
        ],
        threshold: 0.35,
        ignoreLocation: true,
      });
    }

    function card(p: Practice): string {
      const a = document.createElement('a');
      a.href = p.url as string;
      a.className =
        'block p-6 rounded-lg border border-slate-200 dark:border-slate-700 hover:shadow-md hover:border-slate-300 dark:hover:border-slate-600 transition-all';
      const cat = document.createElement('div');
      cat.className = 'text-xs uppercase tracking-wide text-primary mb-1';
      cat.textContent = PRACTICE_LABELS[p.practice_type] ?? '';
      const h = document.createElement('h4');
      h.className = 'text-lg font-semibold mb-2';
      h.textContent = p.title;
      const d = document.createElement('p');
      d.className = 'text-sm text-muted mb-4 card-clamp-3';
      d.textContent = p.description;
      const t = document.createElement('div');
      t.className = 'flex flex-wrap gap-2 items-center';
      const diffSpan = document.createElement('span');
      diffSpan.className = `text-xs px-2 py-0.5 rounded font-medium ${difficultyColors[p.difficulty] || ''}`;
      diffSpan.textContent = p.difficulty;
      const typeSpan = document.createElement('span');
      typeSpan.className =
        'text-xs px-2 py-0.5 rounded bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300';
      typeSpan.textContent = (p.url || '').includes('#entry-') ? 'Note' : 'Article';
      const dateSpan = document.createElement('span');
      dateSpan.className = 'text-xs text-muted';
      if (p.updated) {
        const dd = new Date(p.updated);
        dateSpan.textContent = `Upd ${dd.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' })}`;
      }
      t.append(diffSpan, typeSpan, dateSpan);
      (p.tags || []).slice(0, 3).forEach((tag) => {
        const tagSpan = document.createElement('span');
        tagSpan.className =
          'text-xs px-2 py-0.5 rounded bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400';
        tagSpan.textContent = `#${tag}`;
        t.append(tagSpan);
      });
      a.append(cat, h, d, t);
      return a.outerHTML;
    }

    async function apply() {
      const q = input!.value.trim();
      resetEl?.classList.toggle('hidden', !(q || activeTags.size > 0 || difficulty !== 'all'));

      if (!q && activeTags.size === 0 && difficulty === 'all') {
        results!.classList.add('hidden');
        countEl!.classList.add('hidden');
        sortEl?.classList.add('hidden');
        groups!.classList.remove('hidden');
        toc?.classList.remove('hidden');
        sortMode = 'relevance';
        return;
      }
      await ensureData();
      let items = q && fuse ? fuse.search(q).map((r) => r.item) : all;
      if (activeTags.size > 0) items = items.filter((p) => [...activeTags].every((t) => (p.tags || []).includes(t)));
      if (difficulty !== 'all') items = items.filter((p) => p.difficulty === difficulty);
      if (sortMode === 'newest') {
        items = [...items].sort((a, b) => (b.updated || '').localeCompare(a.updated || ''));
      }
      if (items.length === 0) {
        const emptyDiv = document.createElement('div');
        emptyDiv.className = 'col-span-full py-12 text-center';
        const p = document.createElement('p');
        p.className = 'text-lg font-semibold';
        p.appendChild(document.createTextNode('Nothing found for "'));
        const qs = document.createElement('q');
        qs.textContent = q;
        p.appendChild(qs);
        p.appendChild(document.createTextNode('"'));
        const hint = document.createElement('p');
        hint.className = 'text-sm text-muted mt-1';
        hint.textContent = 'Try different keywords or clear filters';
        emptyDiv.append(p, hint);
        results!.innerHTML = '';
        results!.append(emptyDiv);
        countEl!.classList.add('hidden');
      } else {
        results!.innerHTML = items.map(card).join('');
        countEl!.textContent = `${items.length} practice${items.length === 1 ? '' : 's'} found`;
        countEl!.classList.remove('hidden');
      }
      results!.classList.remove('hidden');
      sortEl?.classList.toggle('hidden', !(q || activeTags.size > 0 || difficulty !== 'all'));
      groups!.classList.add('hidden');
      toc?.classList.add('hidden');
    }

    input.addEventListener('input', apply);
    tagsWrap.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button.learn-tag') as HTMLButtonElement | null;
      if (!btn) return;
      const tag = btn.dataset.tag || '';
      if (activeTags.has(tag)) activeTags.delete(tag);
      else activeTags.add(tag);
      tagsWrap.querySelectorAll('button.learn-tag').forEach((b) => {
        const t = (b as HTMLElement).dataset.tag || '';
        b.classList.toggle('bg-primary', activeTags.has(t));
        b.classList.toggle('text-white', activeTags.has(t));
      });
      void apply();
    });

    diffEl?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.learn-diff-btn') as HTMLButtonElement | null;
      if (!btn) return;
      difficulty = btn.dataset.diff || 'all';
      diffEl.querySelectorAll('.learn-diff-btn').forEach((b) => {
        b.classList.remove('font-semibold', 'text-primary', 'bg-primary', 'text-white', 'rounded-full', 'px-2');
      });
      btn.classList.add('bg-primary', 'text-white', 'rounded-full', 'px-2');
      void apply();
    });

    const topBtn = document.getElementById('learn-top');
    if (topBtn) {
      window.addEventListener('scroll', () => topBtn.classList.toggle('hidden', window.scrollY < 600), {
        passive: true,
      });
      topBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }

    sortEl?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.learn-sort-btn') as HTMLButtonElement | null;
      if (!btn) return;
      sortMode = btn.dataset.sort as 'relevance' | 'newest';
      sortEl!.querySelectorAll('.learn-sort-btn').forEach((b) => {
        b.classList.toggle('font-semibold', b === btn);
        b.classList.toggle('text-primary', b === btn);
      });
      void apply();
    });

    const moreBtn = document.getElementById('learn-tags-more');
    moreBtn?.addEventListener('click', () => {
      const extras = document.querySelectorAll('.learn-tag-extra');
      const allHidden = extras[0]?.classList.contains('hidden');
      extras.forEach((el) => el.classList.toggle('hidden'));
      if (allHidden) {
        moreBtn.textContent = `Show less ▴`;
      } else {
        moreBtn.textContent = `All tags (${extras.length}) ▾`;
      }
    });

    const resetBtn = document.getElementById('learn-reset');
    resetBtn?.addEventListener('click', () => {
      input!.value = '';
      activeTags.clear();
      difficulty = 'all';
      tagsWrap.querySelectorAll('button.learn-tag').forEach((b) => {
        b.classList.remove('bg-primary', 'text-white');
      });
      diffEl?.querySelectorAll('.learn-diff-btn').forEach((b) => {
        b.classList.remove('font-semibold', 'text-primary', 'bg-primary', 'text-white', 'rounded-full', 'px-2');
      });
      const allBtn = diffEl?.querySelector('[data-diff="all"]');
      allBtn?.classList.add('bg-primary', 'text-white', 'rounded-full', 'px-2');
      sortMode = 'relevance';
      sortEl?.querySelectorAll('.learn-sort-btn').forEach((b) => {
        b.classList.remove('font-semibold', 'text-primary');
      });
      const relBtn = sortEl?.querySelector('[data-sort="relevance"]');
      relBtn?.classList.add('font-semibold', 'text-primary');
      void apply();
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
