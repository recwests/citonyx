---
import Layout from '~/layouts/PageLayout.astro';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Schema from '~/components/Schema.astro';
import { getCollection } from 'astro:content';
import { SITE } from 'astrowind:config';
import { entryUrl } from '~/utils/entry';

export const prerender = true;

const allPractices = await getCollection('geoPractices');

const PRACTICE_TYPE_LABELS: Record<string, string> = {
  basics: 'Basics',
  content: 'Content Strategy',
  technical: 'Technical GEO',
  measurement: 'Measurement & Analytics',
  'entity-seo': 'Entity SEO',
  'schema-markup': 'Schema & Structured Data',
  tools: 'Tools & Platforms',
  'case-studies': 'Case Studies',
  monetization: 'Monetization',
};

const difficultyColors: Record<string, string> = {
  beginner: 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
  intermediate: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200',
  advanced: 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200',
};

const grouped = allPractices.reduce<Record<string, typeof allPractices>>((acc, entry) => {
  const pt = entry.data.practice_type;
  if (!pt) return acc;
  if (!acc[pt]) acc[pt] = [];
  acc[pt].push(entry);
  return acc;
}, {});

const tagCounts = new Map<string, number>();
for (const entry of allPractices) {
  for (const tag of entry.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([tag]) => tag);
---

<Layout metadata={{ title: 'GEO Practices' }}>
  <WidgetWrapper>
    <Headline
      title="GEO Practices Guide"
      subtitle="A collection of actionable practices for Generative Engine Optimization"
      tagline="Learn"
      as="h1"
    />

    <Schema
      type="ItemList"
      items={allPractices.map((entry) => ({
        name: entry.data.title,
        url: new URL(entryUrl(entry).href, SITE.site).href,
      }))}
    />

    <div class="mb-10">
      <div class="sticky top-[70px] z-30 -mx-2 px-2 py-2 bg-white/95 dark:bg-slate-900/95 backdrop-blur-sm rounded-lg">
        <label for="learn-search" class="sr-only">Search practices</label>
        <input
          type="search"
          id="learn-search"
          placeholder={`Search ${allPractices.length} practices…`}
          autocomplete="off"
          class="w-full max-w-xl rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary"
        />
      </div>
      <div id="learn-tags" class="mt-4 flex flex-wrap gap-2">
        {
          topTags.map((tag) => (
            <button
              type="button"
              class="learn-tag text-xs px-3 py-1.5 rounded-full border border-slate-300 dark:border-slate-600 hover:border-primary transition-colors"
              data-tag={tag}
            >
              {tag}
            </button>
          ))
        }
      </div>
      <nav id="learn-toc" aria-label="Sections" class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm">
        {
          Object.entries(grouped).map(([topic, entries]) => (
            <a href={`#topic-${topic}`} class="text-primary hover:underline whitespace-nowrap">
              {PRACTICE_TYPE_LABELS[topic] || topic} <span class="text-muted">({entries.length})</span>
            </a>
          ))
        }
      </nav>
      <p id="learn-count" class="mt-3 text-sm text-muted hidden"></p>
    </div>
    <div id="learn-results" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 hidden"></div>
    <button
      type="button"
      id="learn-top"
      aria-label="Back to top"
      class="hidden fixed bottom-6 right-6 z-40 w-11 h-11 rounded-full bg-primary text-white shadow-lg hover:opacity-90 transition-opacity"
      >↑</button
    >

    <div id="learn-groups">
      {
        Object.entries(grouped).map(([topic, entries]) => (
          <div class="mb-12" id={`topic-${topic}`}>
            <div class="flex items-baseline justify-between mb-6">
              <h3 class="text-2xl font-bold">{PRACTICE_TYPE_LABELS[topic] || topic}</h3>
              <a
                href={entries.length >= 5 ? `/learn/${topic}` : '/learn'}
                class="text-sm font-medium text-primary hover:underline"
              >
                View all &rarr;
              </a>
            </div>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {entries.map((entry) => {
                const { href } = entryUrl(entry);
                return (
                  <a
                    href={href}
                    class="block p-6 rounded-lg border border-slate-200 dark:border-slate-700 hover:shadow-md hover:border-slate-300 dark:hover:border-slate-600 transition-all"
                  >
                    <h4 class="text-lg font-semibold mb-2">{entry.data.title}</h4>
                    <p class="text-sm text-muted mb-4 card-clamp-3">{entry.data.description}</p>
                    <div class="flex flex-wrap gap-2 items-center">
                      <span
                        class={`text-xs px-2 py-0.5 rounded font-medium ${difficultyColors[entry.data.difficulty]}`}
                      >
                        {entry.data.difficulty}
                      </span>
                      {entry.data.tags.slice(0, 3).map((tag) => (
                        <span class="text-xs px-2 py-0.5 rounded bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        ))
      }
    </div>
  </WidgetWrapper>
</Layout>

<script>
  import Fuse from 'fuse.js';

  type Practice = {
    slug: string;
    title: string;
    description: string;
    tags: string[];
    difficulty: string;
    url: string | null;
  };

  function init() {
    const input = document.getElementById('learn-search') as HTMLInputElement | null;
    const results = document.getElementById('learn-results');
    const groups = document.getElementById('learn-groups');
    const countEl = document.getElementById('learn-count');
    const tagsWrap = document.getElementById('learn-tags');
    const toc = document.getElementById('learn-toc');
    if (!input || !results || !groups || !countEl || !tagsWrap || input.dataset.ready) return;
    input.dataset.ready = '1';

    let fuse: Fuse<Practice> | null = null;
    let all: Practice[] = [];
    let activeTag = '';

    async function ensureData() {
      if (fuse) return;
      const res = await fetch('/api/practices.json');
      const data = await res.json();
      all = (data.practices as Practice[]).filter((p) => p.url);
      fuse = new Fuse(all, {
        keys: [
          { name: 'title', weight: 2 },
          { name: 'description', weight: 1 },
          { name: 'tags', weight: 1.5 },
        ],
        threshold: 0.35,
        ignoreLocation: true,
      });
    }

    function card(p: Practice): string {
      const a = document.createElement('a');
      a.href = p.url as string;
      a.className =
        'block p-6 rounded-lg border border-slate-200 dark:border-slate-700 hover:shadow-md hover:border-slate-300 dark:hover:border-slate-600 transition-all';
      const h = document.createElement('h4');
      h.className = 'text-lg font-semibold mb-2';
      h.textContent = p.title;
      const d = document.createElement('p');
      d.className = 'text-sm text-muted mb-4 card-clamp-3';
      d.textContent = p.description;
      const t = document.createElement('div');
      t.className = 'flex flex-wrap gap-2 items-center text-xs text-muted';
      t.textContent = [p.difficulty, ...(p.tags || []).slice(0, 3)].filter(Boolean).join(' · ');
      a.append(h, d, t);
      return a.outerHTML;
    }

    async function apply() {
      const q = input!.value.trim();
      if (!q && !activeTag) {
        results!.classList.add('hidden');
        countEl!.classList.add('hidden');
        groups!.classList.remove('hidden');
        toc?.classList.remove('hidden');
        return;
      }
      await ensureData();
      let items = q && fuse ? fuse.search(q).map((r) => r.item) : all;
      if (activeTag) items = items.filter((p) => (p.tags || []).includes(activeTag));
      results!.innerHTML = items.map(card).join('');
      countEl!.textContent = items.length
        ? `${items.length} practice${items.length === 1 ? '' : 's'} found`
        : 'Nothing found — try another query or tag';
      results!.classList.remove('hidden');
      countEl!.classList.remove('hidden');
      groups!.classList.add('hidden');
      toc?.classList.add('hidden');
    }

    input.addEventListener('input', apply);
    tagsWrap.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button.learn-tag') as HTMLButtonElement | null;
      if (!btn) return;
      const tag = btn.dataset.tag || '';
      activeTag = activeTag === tag ? '' : tag;
      tagsWrap.querySelectorAll('button.learn-tag').forEach((b) => {
        b.classList.toggle('bg-primary', b === btn && !!activeTag);
        b.classList.toggle('text-white', b === btn && !!activeTag);
      });
      void apply();
    });

    const topBtn = document.getElementById('learn-top');
    if (topBtn) {
      window.addEventListener('scroll', () => topBtn.classList.toggle('hidden', window.scrollY < 600), {
        passive: true,
      });
      topBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
