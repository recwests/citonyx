---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Counter from './Counter.astro';
import { getLandingStats } from '~/data/stats';

const stats = await getLandingStats();
---

<WidgetWrapper id="stats">
  <Headline
    tagline="Live Counters"
    title="The Experiment by the Numbers"
    subtitle="Computed from our knowledge base and measurement runs at every build — no vendor hype."
  />
  <div class="flex flex-wrap justify-center -m-4 text-center">
    <Counter
      value={String(stats.totalPractices)}
      label="Practices in KB"
      trend={stats.practicesTrend > 0 ? `+${stats.practicesTrend} last 30d` : 'none new in 30d'}
      icon="tabler:books"
    />
    <Counter
      value={String(stats.totalMeasurements)}
      label="Measurements"
      trend={stats.measurementsTrend > 0 ? `+${stats.measurementsTrend} last 30d` : 'none new in 30d'}
      icon="tabler:chart-bar"
    />
    <Counter
      value={`${stats.citedRuns}/${stats.totalRuns}`}
      label="Citations"
      trend={stats.citedTrend > 0 ? `+${stats.citedTrend} cited last 30d` : 'none new in 30d'}
      icon="tabler:link"
    />
    <Counter value={String(stats.daysSinceStart)} label="Days of Experiment" icon="tabler:calendar" />
  </div>
</WidgetWrapper>
