---
import Content from '~/components/widgets/Content.astro';
import Hero from '~/components/widgets/Hero.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About Citonyx',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero tagline="About">
    <Fragment slot="title">
      Citonyx is a <span class="text-accent dark:text-white">Generative Engine Optimization</span> testbed
    </Fragment>

    <Fragment slot="subtitle">
      Citonyx is a public lab that tests what makes content cited by AI answer engines — ChatGPT, Perplexity, Google AI
      Overviews, and Gemini. Instead of theorizing about Generative Engine Optimization (GEO), this site applies GEO
      practices to its own pages and measures whether those engines actually cite them.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    title="What Citonyx does"
    items={[
      {
        title: 'Applies GEO practices to itself',
        description:
          'Every documented practice — structured data, self-contained answers, topical clustering — is implemented on this site so it can be observed in the wild, not just described.',
      },
      {
        title: 'Measures its own citation rate',
        description:
          'Citonyx tracks whether AI engines cite its pages when answering related questions, treating the site as the experiment rather than the marketing.',
      },
      {
        title: 'Publishes the methodology',
        description:
          'The practices, experiments, and how results are measured are kept open so anyone can inspect, reproduce, or challenge them.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">A lab, not a pitch</h3>
      The goal is evidence: does optimizing content for AI search actually change whether AI engines cite it?
    </Fragment>
  </Content>

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="How it's run"
    subtitle="Citonyx is a solo project, not a company. There are no offices and no team — just one operator, AI agents, and an open record of what was tried."
    items={[
      {
        title: 'Solo operator + AI agents',
        description:
          'The site is built and maintained by one person working with AI coding and research agents, which keeps the whole experiment running at near-zero cost.',
        icon: 'tabler:robot',
      },
      {
        title: 'Open methodology and data',
        description:
          'Practices and measurement notes are meant to be public so the results can be verified rather than taken on trust.',
        icon: 'tabler:license',
      },
      {
        title: 'Continuously updated',
        description:
          'As AI engines and citation behavior change, the practices and findings are revised to match what currently works.',
        icon: 'tabler:refresh',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Browse the practices',
        href: '/learn',
      },
    ]}
  >
    <Fragment slot="title">See what's being tested</Fragment>

    <Fragment slot="subtitle">
      The GEO practices applied across this site are documented and explained in the Learn section.
    </Fragment>
  </CallToAction>
</Layout>
