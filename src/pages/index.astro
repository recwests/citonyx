---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Schema from '~/components/Schema.astro';

const metadata = {
  title: 'Citonyx — Generative Engine Optimization (GEO), Measured',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Browse Practices',
        href: '/learn/what-is-geo',
      },
      { text: 'Learn More', href: '#features' },
    ]}
  >
    <Fragment slot="title">
      Optimize Your Content for <span class="text-accent dark:text-white">AI Search</span>
    </Fragment>

    <Fragment slot="subtitle">
      Generative Engine Optimization (GEO) is the practice of making your content discoverable by AI search engines —
      ChatGPT, Perplexity, Google AI Overviews, and more.
      <span class="block mt-4 text-base text-muted">
        AI search drove 1.13B monthly referral visits in 2026 — up 357% from 2024. Is your content ready?
      </span>
    </Fragment>
  </Hero>

  <Stats
    stats={[
      { title: 'GEO Research Cycles', amount: '14+' },
      { title: 'Lines of Research Notes', amount: '2,200+' },
      { title: 'AI Referral Visit Growth', amount: '357%' },
      { title: 'Higher Conversion vs Organic', amount: '9x' },
    ]}
  />

  <Features
    id="features"
    tagline="What is GEO"
    title="Generative Engine Optimization in Practice"
    subtitle="Evidence-based techniques that work across ChatGPT, Perplexity, Claude, and Google AI Overviews — backed by research and real-world testing."
    items={[
      {
        title: 'Schema.org Markup',
        description:
          'Structured data helps AI models understand your content type, author, and relationships. Article, FAQPage, and LearningResource schemas improve citation rates by 2-3x.',
        icon: 'tabler:code',
      },
      {
        title: 'Self-Contained Answers',
        description:
          'AI models often cite only the first 2 sentences. Every page should answer one question completely in its opening paragraph — no fluff, no preamble.',
        icon: 'tabler:quote',
      },
      {
        title: 'Brand Mentions Strategy',
        description:
          'Ahrefs 2026 study: brand web mentions predict AI citation 3x better than backlinks. Earned media on authoritative domains outperforms link building for AI visibility.',
        icon: 'tabler:bulb',
      },
      {
        title: 'Topical Authority',
        description:
          'AI models evaluate topical clusters, not individual pages. A site with 50 GEO articles beats a site with 1 great article and 49 unrelated pages.',
        icon: 'tabler:hierarchy-2',
      },
      {
        title: 'Multi-Platform Adaptation',
        description:
          'ChatGPT, Perplexity, Gemini, and Claude each process content differently. Techniques must be tested per platform — what works on one may not work on another.',
        icon: 'tabler:device-desktop-analytics',
      },
      {
        title: 'Structured Content Format',
        description:
          'Clear headings, lists, tables, and concise definitions help AI extract facts reliably. P-A-S-E-C format (Problem-Agitation-Solution-Evidence-Conclusion) maximizes citability.',
        icon: 'tabler:list-check',
      },
    ]}
  />

  <Content
    isReversed
    tagline="The Evidence"
    title="Data-Driven, Not Theory-Based"
    items={[
      {
        title: '1.13B monthly AI referral visits',
        description:
          'AI search drove 1.13B monthly referral visits in 2026 — a 357% increase from 2024. By 2028, AI-powered search is projected to surpass traditional search traffic.',
      },
      {
        title: '9x higher conversion than organic',
        description:
          'Erlin AI tracked 500+ brands: ChatGPT referrals convert at 15.9% vs 1.76% organic baseline. Perplexity converts at 10.5%, Claude at 5%.',
      },
      {
        title: 'Brand mentions > backlinks for AI',
        description:
          'Ahrefs study of 75K brands: mentions correlate 0.664 with AI citation vs 0.218 for backlinks. This changes where to invest optimization effort.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Built on Research, Not Guesswork
      </h3>
      Every practice in this guide is sourced from independent studies, live experiments, and verified results.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <FAQs
    title="Frequently Asked Questions About GEO"
    subtitle="Common questions about optimizing content for AI search engines."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'What is GEO in simple terms?',
        description:
          'GEO (Generative Engine Optimization) is the practice of structuring your content so AI search engines like ChatGPT and Perplexity cite it in their answers. Unlike SEO which targets Google rankings, GEO targets AI citation.',
      },
      {
        title: 'How is GEO different from SEO?',
        description:
          'SEO optimizes for a ranked list of blue links. GEO optimizes for citation in a generated answer. The signals differ: SEO relies on backlinks, GEO on brand mentions and structured data. Both matter, but the strategies are distinct.',
      },
      {
        title: 'Do I need technical skills for GEO?',
        description:
          'The basics are accessible: write clear, self-contained answers and add Schema.org markup. Advanced GEO involves brand mention monitoring, multi-platform testing, and topical authority building — but you can start with content changes alone.',
      },
      {
        title: 'Which AI search engines should I optimize for?',
        description:
          'Start with ChatGPT (81% market share), then Perplexity and Google AI Overviews. Different AI models process content differently — platform-specific testing is essential.',
      },
      {
        title: 'How long until I see results from GEO?',
        description:
          'AI citation can improve within weeks of implementing Schema.org markup and self-contained answers. Brand mention strategies take longer — 2-4 months to see measurable impact.',
      },
      {
        title: 'Does GEO replace SEO?',
        description:
          'No. GEO is a parallel optimization layer. Google still drives the majority of web traffic. Maintain your SEO while adding GEO practices for AI search visibility.',
      },
    ]}
  />

  <Schema
    type="FAQPage"
    questions={[
      {
        question: 'What is GEO in simple terms?',
        answer:
          'GEO (Generative Engine Optimization) is the practice of structuring your content so AI search engines like ChatGPT and Perplexity cite it in their answers. Unlike SEO which targets Google rankings, GEO targets AI citation.',
      },
      {
        question: 'How is GEO different from SEO?',
        answer:
          'SEO optimizes for a ranked list of blue links. GEO optimizes for citation in a generated answer. The signals differ: SEO relies on backlinks, GEO on brand mentions and structured data. Both matter, but the strategies are distinct.',
      },
      {
        question: 'Do I need technical skills for GEO?',
        answer:
          'The basics are accessible: write clear, self-contained answers and add Schema.org markup. Advanced GEO involves brand mention monitoring, multi-platform testing, and topical authority building — but you can start with content changes alone.',
      },
      {
        question: 'Which AI search engines should I optimize for?',
        answer:
          'Start with ChatGPT (81% market share), then Perplexity and Google AI Overviews. Different AI models process content differently — platform-specific testing is essential.',
      },
      {
        question: 'How long until I see results from GEO?',
        answer:
          'AI citation can improve within weeks of implementing Schema.org markup and self-contained answers. Brand mention strategies take longer — 2-4 months to see measurable impact.',
      },
      {
        question: 'Does GEO replace SEO?',
        answer:
          'No. GEO is a parallel optimization layer. Google still drives the majority of web traffic. Maintain your SEO while adding GEO practices for AI search visibility.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start Learning',
        href: '/learn/what-is-geo',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to Make Your Content <br class="block sm:hidden" /><span class="sm:whitespace-nowrap">AI-Ready?</span>
    </Fragment>

    <Fragment slot="subtitle">
      Explore evidence-based GEO practices, backed by real research and platform-specific testing.
    </Fragment>
  </CallToAction>
</Layout>
