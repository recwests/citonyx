---
import Layout from '~/layouts/PageLayout.astro';
import { Content } from '~/data/state-of-geo.md';

const metadata = {
  title: 'State of GEO — How Generative Engine Optimization Works Now',
  description:
    'A continuously-updated living document on Generative Engine Optimization: platform divergence, entity signals, the schema paradox, and the practices that actually move AI citations across ChatGPT, Perplexity, Claude, and Gemini.',
  canonical: 'https://citonyx.com/state-of-geo',
  robots: {
    index: true,
    follow: true,
  },
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <div
      class="mx-auto prose prose-lg max-w-2xl dark:prose-invert dark:prose-headings:text-slate-300 prose-md prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-img:rounded-md prose-img:shadow-lg mt-8"
    >
      <Content />
    </div>
  </section>
</Layout>
